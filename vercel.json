{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    {
      "src": "/",
      "methods": ["POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "dest": "/api/index.py"
    },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*\\..*)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
