{
  "version": 2,
  "public": true,
  "installCommand": "npm install && pip install -r requirements.txt",
  "cleanUrls": true,
  "env": {
    "TRYONYOU_PUBLIC_DOMAIN": "tryonyou.app",
    "APP_ENV": "production",
    "STRICT_DIVINEO_MODE": "true",
    "SERVER_URL": "https://tryonyou-v100-final-201614778520.us-west1.run.app",
    "PRIMARY_DOMAIN": "tryonyou.app",
    "REPO_FULLNAME": "LVT-ENG/TRYONME-TRYONYOU-ABVETOS--INTELLIGENCE--SYSTEM",
    "AVBET_API_URL": "https://api.avbet.com",
    "VITE_API_URL": "https://api.tryonyou.app",
    "VITE_ENVIRONMENT": "production",
    "VITE_GITHUB_REPO": "LVT-ENG/TRYONME-TRYONYOU-ABVETOS--INTELLIGENCE--SYSTEM",
    "VITE_PRODUCTION_URL": "https://tryonyou.app",
    "VITE_DASHBOARD_URL": "https://tryonyou.app/dashboard/abvetos-dashboard/"
  },
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/vetos_core_inference.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/vetos_core_inference",
      "dest": "/api/vetos_core_inference.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/api",
      "dest": "/api/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=*, microphone=(), geolocation=()"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
