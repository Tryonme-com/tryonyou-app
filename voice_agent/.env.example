# --- Google AI / Gemini (obligatorio) ---
GEMINI_API_KEY=
# Alternativa:
# GOOGLE_API_KEY=

# --- Modelo Gemini (opcional) ---
# GEMINI_MODEL=gemini-1.5-flash

# --- URL pública del túnel (Twilio webhook) ---
# Ejemplo: https://abc.ngrok-free.app  (sin barra final)
VOICE_PUBLIC_URL=

# --- Puerto del servidor (opcional, default 8000) ---
# PORT=8000
