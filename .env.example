# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
PORT=4242
LOG_LEVEL=INFO

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_API_KEY=sk_test_xxx
STRIPE_ENDPOINT_SECRET=whsec_test_xxx

# ── Database ──────────────────────────────────────────────────────────────────
TRYONYOU_DB_PATH=/tmp/tryonyou_leads.sqlite

# ── Redis (required for production idempotency + queue) ──────────────────────
# Omit or leave blank to use the in-memory fallback (single-process dev only)
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_KEY=stripe:queue:pending
REDIS_DLQ_KEY=stripe:queue:dlq
REDIS_LOCK_TTL=30
REDIS_EVENT_TTL=604800       # 7 days in seconds

# ── Jules worker ──────────────────────────────────────────────────────────────
# Run worker: PYTHONPATH=api python -m orchestrators.jules_worker
MAX_RETRIES=3
WORKER_POLL_TIMEOUT=5

# ── AI providers (optional — leave blank to disable) ─────────────────────────
AI_PROVIDER=google            # google | manus

# Google AI Studio
GOOGLE_AI_API_KEY=xxx
GOOGLE_AI_MODEL=gemini-1.5-flash

# Manus AI
MANUS_API_KEY=xxx
MANUS_BASE_URL=https://api.manus.ai/v1
MANUS_TIMEOUT_S=10
