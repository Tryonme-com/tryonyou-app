# Copia a .env (no subas .env a git). Referencia TryOnYou / Make eu2 org 5247214.
#
# NO uses la URL del dashboard como webhook:
#   https://eu2.make.com/organization/5247214/dashboard  ← solo para entrar en Make
#
# MAKE_WEBHOOK_URL debe ser la URL del módulo "Webhooks > Custom webhook" del escenario,
# típicamente: https://hook.eu2.make.com/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAKE_WEBHOOK_URL=

ELEVENLABS_API_KEY=
TELEGRAM_BOT_TOKEN=
# Alias soportado en scripts Omega / VIP (mismo valor que BotFather):
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Google AI Studio / Gemini (Oráculo Mesa de los Listos)
GOOGLE_STUDIO_API_KEY=
# opcional: misma clave que en Google AI Studio
# GEMINI_API_KEY=

# Vercel CLI (vercel_deploy_orchestrator.py); revocar si el token se filtró
VERCEL_TOKEN=
