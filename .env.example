# ─── TryOnYou — Environment Variables Template ────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit the .env file — it is listed in .gitignore.

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Your Stripe secret API key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe webhook signing secret (whsec_...) — obtained from Stripe Dashboard
# or from `stripe listen --print-secret` for local development.
STRIPE_ENDPOINT_SECRET=whsec_replace_me

# ── Database ────────────────────────────────────────────────────────────────────
# SQLite database path. Defaults to /tmp/tryonyou_leads.sqlite (writable on Vercel).
# For local development you can use a local path, e.g. ./data/tryonyou.sqlite
TRYONYOU_DB_PATH=/tmp/tryonyou_leads.sqlite

# ── Application ─────────────────────────────────────────────────────────────────
LAFAYETTE_VERIFY_BASE_URL=https://tryonyou.lafayette.demo/verify/

# ── Jules async worker (optional) ───────────────────────────────────────────────
# If Jules (or another worker) consumes events via HTTP, set the worker URL here.
# The enqueue_event() function in api/index.py can be extended to POST to this URL.
# JULES_WORKER_URL=https://your-jules-worker.example.com/process-stripe-event

# ── Redis / Celery (optional — replace SQLite queue with a real broker) ──────────
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Google Sheets / Pennylane sync (optional) ────────────────────────────────────
# GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
# PENNYLANE_API_TOKEN=replace_me
