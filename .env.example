APP_ENV=development
PORT=4242
LOG_LEVEL=INFO
STRIPE_API_KEY=sk_test_xxx
# Canonical backend secret key (overrides STRIPE_API_KEY when set)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_ENDPOINT_SECRET=whsec_test_xxx
# Publishable key — safe to expose to the browser via Vite
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
REDIS_URL=redis://localhost:6379/0
REDIS_QUEUE_KEY=stripe:events:queue
REDIS_DEAD_LETTER_KEY=stripe:events:dlq
REDIS_RETRY_KEY=stripe:events:retry
EVENT_TTL_SECONDS=604800
LOCK_TTL_SECONDS=60
MAX_RETRY_ATTEMPTS=5
RETRY_BACKOFF_BASE_SECONDS=2
RETRY_MAX_BACKOFF_SECONDS=300
MAX_ERROR_LENGTH=600
WORKER_POP_TIMEOUT_SECONDS=2
AI_PROVIDER=google
AI_TIMEOUT_SECONDS=20
GOOGLE_AI_API_KEY=xxx
MANUS_API_KEY=xxx
MANUS_BASE_URL=https://api.manus.example
