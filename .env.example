# --- Entorno de aplicación ---
APP_ENV=production
STRICT_DIVINEO_MODE=true
SERVER_URL=https://tryonyou-v100-final-201614778520.us-west1.run.app
PRIMARY_DOMAIN=tryonyou.app
REPO_FULLNAME=LVT-ENG/TRYONME-TRYONYOU-ABVETOS--INTELLIGENCE--SYSTEM

# --- Dominio público (referencia despliegue) ---
TRYONYOU_PUBLIC_DOMAIN=tryonyou.app

# --- Make.com (hooks estables; NO uses la URL del dashboard como webhook) ---
# Escenario típico: Webhooks > Custom webhook → https://hook.eu2.make.com/...
MAKE_WEBHOOK_URL=
MAKE_ESPEJO_WEBHOOK_URL=
TRYONYOU_LEAD_WEBHOOK_URL=
MAKE_LEADS_WEBHOOK_URL=

# --- Divineo_Leads_DB (SQLite alta fidelidad · prioridad DIVINEO > LEADS) ---
DIVINEO_LEADS_DB_PATH=
LEADS_DB_PATH=

# --- Email / Google Sheets (guía «Lafayette Pilot» · NO son leídas por api/index.py hoy) ---
# api/index.py (Vercel): leads por POST → SQLite en DIVINEO_LEADS_DB_PATH / LEADS_DB_PATH
# (véase _lead_db_path en api/index.py) y opcional reenvío JSON a Make con:
# TRYONYOU_LEAD_WEBHOOK_URL / MAKE_LEADS_WEBHOOK_URL / MAKE_WEBHOOK_URL.
# Si necesitás espejo en hoja «Divineo_Leads_DB», cablealo en Make o en un script batch;
# estas claves sirven a scripts locales y a despliegues que aún usen IMAP/Sheets.
#
# IMAP (p. ej. extraer_expediente_bpifrance_imap.py): EMAIL_USER + EMAIL_PASS o alias E50_*.

EMAIL_USER=your-gmail@example.com
EMAIL_PASS=your-16-char-app-password
E50_SMTP_USER=your-smtp-user@example.com
E50_SMTP_PASS=your-smtp-password
IMAP_SERVER=imap.gmail.com
IMAP_FOLDER=INBOX
#
# Google Sheets (cuenta de servicio JSON, guía Lafayette): para pipelines externos;
# api/index.py no consume GOOGLE_CREDENTIALS_JSON ni SHEET_NAME en este repo.
GOOGLE_CREDENTIALS_JSON=
SHEET_NAME=Divineo_Leads_DB

# --- Slack (reemplazo operativo SMTP; api/index.py, jules_force_execution.py) ---
SLACK_WEBHOOK_URL=

# --- Telegram (Búnker, VIP Fatality, señales operativas) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_FORMAT=plain
SKIP_TELEGRAM=

# --- ElevenLabs (voz; priorizar protocolo vault: Serena / Lily según rol) ---
